# BorgOS Platform - Environment Configuration
# Copy this file to .env and adjust values

# Database
# SQLite (default, zero-config)
DATABASE_URL=sqlite+aiosqlite:///./borgos.db
# PostgreSQL (optional)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/borgos

# Authentication
SECRET_KEY=change-me-in-production-use-a-long-random-string
INITIAL_PASSWORD=borgborg

# Archon Integration
ARCHON_PATH=/opt/archon

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Server
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_RELOAD=true
