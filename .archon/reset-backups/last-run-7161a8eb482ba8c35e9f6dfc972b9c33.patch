 EXCLUDED_DIRS = {"borgos_copies", ".git", "__pycache__", "node_modules", ".venv", "venv"}
 
 
+def write_asset_file(archon_root: str, subdir: str, payload: dict) -> Path:
+    """Write a YAML asset file under archon_root/subdir. Path-contained.
+
+    Returns the resolved Path of the written file.
+    """
+    root = Path(archon_root).resolve()
+    target_dir = (root / subdir).resolve()
+    if not target_dir.is_relative_to(root):
+        raise ValueError("subdir escapes ARCHON_PATH")
+    target_dir.mkdir(parents=True, exist_ok=True)
+
+    slug = _slugify(str(payload.get("name", "")))
+    path = (target_dir / f"{slug}.yaml").resolve()
+    if not path.is_relative_to(root):
+        raise ValueError("resolved path escapes ARCHON_PATH")
+
+    # Canonical YAML — preserve key order: name, type, description, tags, body.
+    doc: dict[str, Any] = {
+        "name": payload["name"],
+        "type": payload.get("type", "unknown"),
+    }
+    if payload.get("description"):
+        doc["description"] = payload["description"]
+    if payload.get("tags"):
+        doc["tags"] = payload["tags"]
+
+    raw_body = payload.get("raw_content") or ""
+    # If raw_content is valid YAML mapping, merge top-level keys not already in doc.
+    try:
+        parsed_body = yaml.safe_load(raw_body) if raw_body.strip() else None
+        if isinstance(parsed_body, dict):
+            for k, v in parsed_body.items():
+                if k not in doc:
+                    doc[k] = v
+    except yaml.YAMLError:
+        # raw_content was non-YAML free text; write it as a 'body' field.
+        doc["body"] = raw_body
+
+    yaml_text = yaml.safe_dump(doc, sort_keys=False, allow_unicode=True)
+    path.write_text(yaml_text, encoding="utf-8")
+    return path
+
+
 def scan_directory(archon_path: str) -> list[dict[str, Any]]:
     """Recursively scan archon_path for YAML/JSON asset files."""
     path = Path(archon_path)
