+_SLUG_RE = re.compile(r"[^a-z0-9_-]+")
+
+
+def _slugify(name: str) -> str:
+    """Slugify a name for use as a filename. Raises ValueError on invalid input."""
+    slug = _SLUG_RE.sub("-", name.lower()).strip("-")
+    if not slug or ".." in slug:
+        raise ValueError(f"Invalid asset name for slug: {name!r}")
