+# ── Write-CRUD helpers ──────────────────────────────────────────────────────
+
+def _check_write_enabled() -> None:
+    """Raise 503 when ARCHON_WRITE_ENABLED is false."""
+    if not settings.archon_write_enabled:
+        raise HTTPException(status_code=503, detail="Archon writes are disabled")
+
+
+async def create_asset(db: AsyncSession, payload: dict) -> ArchonAsset:
+    """Create a new asset: write YAML file → parse → insert DB row."""
+    _check_write_enabled()
+    subdir = payload.pop("subdir", None) or "borgos_authored"
+    path = write_asset_file(settings.archon_path, subdir, payload)
+    parsed = parse_asset_file(path)
+    if not parsed:
+        raise HTTPException(status_code=500, detail="Could not re-parse written file")
+
+    asset = ArchonAsset(
+        name=parsed["name"],
+        type=parsed["type"],
+        description=parsed["description"],
+        tags=parsed["tags"],
+        file_path=parsed["file_path"],
+        raw_content=parsed["raw_content"],
+        last_scanned=parsed["last_scanned"],
+        is_favorite=False,
+        custom_tags="[]",
+    )
+    db.add(asset)
+    await db.commit()
+    await db.refresh(asset)
+    return asset
+
+
+async def update_asset(db: AsyncSession, asset_id: int, patch: dict) -> ArchonAsset | None:
+    """Update an asset: rewrite file for file-bound fields, update DB for overlay fields."""
+    _check_write_enabled()
+    asset = await get_asset(db, asset_id)
+    if not asset:
+        return None
+
+    # File-bound fields: name, description, tags, raw_content
+    file_fields = {k: patch[k] for k in ("name", "description", "tags", "raw_content") if k in patch}
+    if file_fields:
+        current_path = Path(asset.file_path)
+        merged = {
+            "name": patch.get("name", asset.name),
+            "type": asset.type,
+            "description": patch.get("description", asset.description),
+            "tags": patch.get("tags") if "tags" in patch else json.loads(asset.tags or "[]"),
+            "raw_content": patch.get("raw_content", asset.raw_content),
+        }
+
+        # Write directly to the existing file path (do not relocate).
+        doc = {k: v for k, v in {
+            "name": merged["name"],
+            "type": merged["type"],
+            "description": merged["description"],
+            "tags": merged["tags"],
+        }.items() if v is not None}
+        current_path.write_text(
+            yaml.safe_dump(doc, sort_keys=False, allow_unicode=True),
+            encoding="utf-8",
+        )
+        parsed = parse_asset_file(current_path)
+        if parsed:
+            asset.name = parsed["name"]
+            asset.description = parsed["description"]
+            asset.tags = parsed["tags"]
+            asset.raw_content = parsed["raw_content"]
+            asset.last_scanned = parsed["last_scanned"]
+
+    # DB-only overlay fields
+    if "custom_notes" in patch:
+        asset.custom_notes = patch["custom_notes"]
+    if "custom_tags" in patch:
+        asset.custom_tags = json.dumps(patch["custom_tags"])
+
+    await db.commit()
+    await db.refresh(asset)
+    return asset
+
+
+async def delete_asset(db: AsyncSession, asset_id: int) -> str | None:
+    """Delete an asset: remove file + DB row. Returns 'deleted', 'linked', or None."""
+    _check_write_enabled()
+    asset = await get_asset(db, asset_id)
+    if not asset:
+        return None
+    if asset.linked_task_id is not None:
+        return "linked"
+    Path(asset.file_path).unlink(missing_ok=True)
+    await db.delete(asset)
+    await db.commit()
+    return "deleted"
+
+
+# ── P02: Asset ↔ Task linking, run history, execution ─────────────────────
+
+
+async def link_asset(db: AsyncSession, asset_id: int, task_id: int) -> dict | None:
+    """Link an asset to a Task. Returns dict with asset_id, task_id, task_name."""
+    asset = await get_asset(db, asset_id)
+    if not asset:
+        return None
+    task = (await db.execute(select(Task).where(Task.id == task_id))).scalar_one_or_none()
+    if not task:
+        return {"error": "task_not_found"}
+    asset.linked_task_id = task.id
+    await db.commit()
+    await db.refresh(asset)
+    return {"asset_id": asset.id, "task_id": task.id, "task_name": task.name}
+
+
+async def unlink_asset(db: AsyncSession, asset_id: int) -> bool:
+    """Unlink an asset from its Task."""
+    asset = await get_asset(db, asset_id)
+    if not asset:
+        return False
+    asset.linked_task_id = None
+    await db.commit()
+    return True
+
+
+async def _ensure_runnable_task(db: AsyncSession, asset: ArchonAsset) -> int:
+    """Ensure the asset has a linked Task, creating an ephemeral one if needed."""
+    if asset.linked_task_id:
+        # Verify the linked task still exists
+        task = await task_service.get_task(db, asset.linked_task_id)
+        if task:
+            return asset.linked_task_id
+        # Stale reference — fall through to create new
+    task = await task_service.create_task(
+        db,
+        name=f"archon:{asset.name}",
+        task_type="archon_workflow",
+        archon_workflow_name=asset.name,
+        description=f"Auto-created for ArchonAsset {asset.id}",
+        tags=["archon-ephemeral"],
+    )
+    asset.linked_task_id = task.id
+    await db.commit()
+    return task.id
+
+
+async def run_asset(db: AsyncSession, asset_id: int) -> dict | None:
+    """Trigger execution of an asset. Creates ephemeral Task if not linked."""
+    asset = await get_asset(db, asset_id)
+    if not asset:
+        return None
+    task_id = await _ensure_runnable_task(db, asset)
+    run_id = await task_service.run_task_now(db, task_id)
+    return {"task_run_id": run_id, "task_id": task_id, "message": "triggered"}
+
+
+async def get_asset_runs(
+    db: AsyncSession, asset_id: int, page: int = 1, size: int = 20
+) -> dict | None:
+    """Get paginated run history for an asset's linked Task."""
+    asset = await get_asset(db, asset_id)
+    if not asset:
+        return None
+    if not asset.linked_task_id:
+        return {"items": [], "total": 0, "page": page, "size": size, "pages": 0}
+    return await task_service.get_task_runs(db, asset.linked_task_id, page, size)
+
+
+async def enrich_asset_with_run_info(asset: ArchonAsset, db: AsyncSession) -> dict:
+    """Compute linked_task_name, last_run_status, last_run_at for an asset."""
+    extra: dict = {"linked_task_name": None, "last_run_status": None, "last_run_at": None}
+    if asset.linked_task_id:
+        task = (await db.execute(select(Task).where(Task.id == asset.linked_task_id))).scalar_one_or_none()
+        if task:
+            extra["linked_task_name"] = task.name
+        # Latest run
+        latest = (await db.execute(
+            select(TaskRun)
+            .where(TaskRun.task_id == asset.linked_task_id)
+            .order_by(desc(TaskRun.started_at))
+            .limit(1)
+        )).scalar_one_or_none()
+        if latest:
+            extra["last_run_status"] = latest.status
+            extra["last_run_at"] = latest.started_at.isoformat() if latest.started_at else None
+    return extra
