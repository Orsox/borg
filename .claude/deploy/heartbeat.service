[Unit]
Description=Orsox's Second Brain — Heartbeat
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/bernd/Workbench/borg
ExecStart=/home/bernd/.claude/venv/bin/python3 .claude/scripts/heartbeat.py
EnvironmentFile=/home/bernd/Workbench/borg/.env
# Pass through display env for notify-send (desktop)
Environment=DISPLAY=:0
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

# Logging: view with: journalctl --user -u heartbeat.service -f
StandardOutput=journal
StandardError=journal
