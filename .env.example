# Second Brain — Integration Credentials
# Copy this to .env and fill in your values. Never commit .env to git.

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net
JIRA_TOKEN=your-personal-access-token-or-api-token
# JIRA_EMAIL=you@company.com       # required for Jira Cloud only
# JIRA_CLOUD=true                  # set to true for Jira Cloud; omit for Server/DC
# JIRA_PROJECT_KEYS=AI,AGENT       # comma-separated; overrides USER.md

# ── GitLab ───────────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your-personal-access-token   # scope: read_api
# GITLAB_MY_NAMESPACES=orsox,mycompany/ai-team   # comma-separated; overrides USER.md

# ── Polarion ─────────────────────────────────────────────────────────────────
POLARION_URL=https://polarion.yourcompany.com
POLARION_TOKEN=your-polarion-pat           # My Profile → Personal Access Tokens
# POLARION_PROJECT_IDS=REQ_2024,SW_ARCH    # comma-separated; overrides USER.md

# ── Microsoft Teams + OneDrive (shared Azure app) ────────────────────────────
# Steps:
#   1. Azure Portal → Microsoft Entra ID → App registrations → New registration
#   2. API permissions: Chat.Read, ChannelMessage.Read.All (admin consent needed),
#                       Files.Read, Files.Read.All, User.Read
#   3. Copy the client_id and tenant_id below
#   4. Run: query.py teams --auth   (one-time device code flow)
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_TENANT_ID=your-azure-tenant-id

# ── Claude API (required for heartbeat + reflection) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Teams Bot (Phase 7) ──────────────────────────────────────────────────────
# Steps:
#   1. Azure Portal → Bot Services → Create a Bot (Azure Bot)
#   2. Note the Microsoft App ID shown after creation
#   3. Certificates & secrets → New client secret → copy the Value immediately
#   4. Set the messaging endpoint: https://<your-vps-domain>/webhook/teams
#   5. In Teams Admin Center (or via manifest), install the bot for your account
TEAMS_BOT_APP_ID=your-bot-app-id
TEAMS_BOT_APP_PASSWORD=your-bot-client-secret

# ── Database (Phase 9: VPS) ──────────────────────────────────────────────────
# Leave unset for local SQLite (~/.claude/data/memory.db)
# DB_URL=postgresql://user:password@vps-host:5432/second_brain
